NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/foodapp

# JWT
JWT_SECRET=change_this_in_production_use_random_64_char_string
JWT_EXPIRE=30d

# Admin
ADMIN_EMAIL=admin@foodapp.pk
ADMIN_PASSWORD=admin123

# App URL
APP_URL=http://localhost:5173
CUSTOMER_APP_DOMAIN=foodapp.pk

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5000000
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,gif

# CORS (comma-separated production origins)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@foodapp.pk
FROM_NAME=FoodApp

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+14155238886
